# Scarabeo Worker Service Configuration
# Copy this file to .env and update values for your environment

# Service
DEBUG=false

# Database
DATABASE_URL=postgresql://scarabeo:scarabeo_dev_password@localhost:5432/scarabeo

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=scarabeo_dev_password
WORKER_DISPATCH_QUEUE=scarabeo:workers:dispatch

# S3/MinIO Storage
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=scarabeo
S3_SECRET_KEY=scarabeo_dev_password
S3_BUCKET=scarabeo-samples
S3_REGION=us-east-1

# Docker
DOCKER_IMAGE_TRIAGE=scarabeo/triage-universal:latest
DOCKER_NETWORK_DISABLED=true
DOCKER_READONLY_ROOTFS=true

# Resource Limits
DOCKER_CPU_LIMIT=2.0
DOCKER_MEMORY_LIMIT=2g

# Analyzer Settings
ANALYZER_CHUNK_SIZE=4096
ANALYZER_MAX_STRINGS=10000
ANALYZER_HIGH_ENTROPY_THRESHOLD=7.5
