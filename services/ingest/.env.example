# Scarabeo Ingest Service Configuration
# Copy this file to .env and update values for your environment

# Service
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Database
DATABASE_URL=postgresql://scarabeo:scarabeo_dev_password@localhost:5432/scarabeo

# S3/MinIO Storage
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=scarabeo
S3_SECRET_KEY=scarabeo_dev_password
S3_BUCKET=scarabeo-samples
S3_REGION=us-east-1

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=scarabeo_dev_password

# Upload Limits
MAX_UPLOAD_SIZE_MB=50

# Job Queue
JOB_QUEUE_NAME=scarabeo:jobs:triage
