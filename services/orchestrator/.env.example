# Scarabeo Orchestrator Service Configuration
# Copy this file to .env and update values for your environment

# Service
HOST=0.0.0.0
PORT=8001
DEBUG=false

# Admin Authentication
ADMIN_TOKEN=orchestrator_admin_secret_token

# Database
DATABASE_URL=postgresql://scarabeo:scarabeo_dev_password@localhost:5432/scarabeo

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=scarabeo_dev_password

# Job Queues
JOB_QUEUE_NAME=scarabeo:jobs:triage
WORKER_DISPATCH_QUEUE=scarabeo:workers:dispatch

# Worker Limits
MAX_CONCURRENT_JOBS=10
JOB_TIMEOUT_SECONDS=600

# S3/MinIO (for report storage verification)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=scarabeo
S3_SECRET_KEY=scarabeo_dev_password
S3_BUCKET=scarabeo-samples
