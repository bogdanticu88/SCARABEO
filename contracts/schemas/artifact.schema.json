{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scarabeo.io/schemas/artifact.schema.json",
  "title": "Analysis Artifact",
  "description": "Schema for artifacts produced during analysis",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "path",
    "sha256",
    "produced_by"
  ],
  "properties": {
    "type": {
      "type": "string",
      "description": "Type of artifact (e.g., screenshot, pcap, memory_dump, extracted_file)"
    },
    "path": {
      "type": "string",
      "description": "Path to the artifact in storage"
    },
    "sha256": {
      "type": "string",
      "description": "SHA-256 hash of the artifact",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "mime": {
      "type": "string",
      "description": "MIME type of the artifact"
    },
    "size_bytes": {
      "type": "integer",
      "description": "Size of the artifact in bytes",
      "minimum": 0
    },
    "produced_by": {
      "type": "string",
      "description": "Name of the engine or analyzer that produced this artifact"
    },
    "safe_preview": {
      "type": "string",
      "description": "Sanitized preview content (for text-based artifacts)"
    }
  }
}
